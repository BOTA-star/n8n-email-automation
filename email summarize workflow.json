    {
      "parameters": {
        "language": "python",
        "pythonCode": "items = _input.all()\n\noutputItems = []\n\nfor item in items:\n\n    output = item[\"json\"].get(\"output\", {})\n\n    outputItems.append({\n        \"json\": {\n            \"text\": output.get(\"text\", \"\"),\n            \"file_name\": output.get(\"file_name\", \"\"),\n            \"sender\": output.get(\"sender\", \"\"),\n            \"subject\": output.get(\"subject\", \"\"),\n            \"email_body\": output.get(\"email_body\", \"\")\n        }\n    })\n\nreturn outputItems"
      },
