    {
      "parameters": {
        "language": "python",
        "pythonCode": "items = _input.all()\noutput_items = []\n\nfor item in items:\n    body = item[\"json\"].get(\"text\") or item[\"json\"].get(\"html\") or \"Nội dung mail trống\"\n    subject = item[\"json\"].get(\"subject\") or \"Không có tiêu đề\"\n    sender = \"Không rõ người gửi\"\n\n    if item[\"json\"].get(\"from\") and item[\"json\"][\"from\"].get(\"text\"):\n        sender = item[\"json\"][\"from\"][\"text\"]\n    elif isinstance(item[\"json\"].get(\"from\"), str):\n        sender = item[\"json\"][\"from\"]\n\n    binary_data = item.get(\"binary\")\n\n    # Nếu CÓ file đính kèm\n    if binary_data and len(binary_data.keys()) > 0:\n        for key in binary_data.keys():\n            file_info = binary_data[key]\n            file_name = file_info.get(\"fileName\") or \"File_Dinh_Kem\"\n            file_ext = (file_name.split(\".\")[-1] if \".\" in file_name else \"\").lower()\n\n            file_type = \"other\"\n            if file_ext == \"pdf\":\n                file_type = \"pdf\"\n            elif file_ext in [\"txt\", \"csv\", \"json\", \"xml\"]:\n                file_type = \"text\"\n\n            output_items.append({\n                \"json\": {\n                    \"subject\": subject,\n                    \"sender\": sender,\n                    \"email_body\": body,\n                    \"file_name\": file_name,\n                    \"file_type\": file_type,\n                    \"has_attachment\": True\n                },\n                \"binary\": {\n                    \"data\": file_info  # Luôn đưa về key 'data' cố định\n                }\n            })\n    else:\n        # Nếu KHÔNG CÓ file đính kèm\n        output_items.append({\n            \"json\": {\n                \"subject\": subject,\n                \"sender\": sender,\n                \"email_body\": body,\n                \"file_name\": None,\n                \"file_type\": \"none\",\n                \"has_attachment\": False\n            }\n        })\n\nreturn output_items"
      },
