      "parameters": {
        "language": "python",
        "pythonCode": "items = _input.all()\n\noutputItems = []\n\nif not items or len(items) == 0:\n    return [{\n        \"json\": {\n            \"all_files_summary\": \"Email thuần túy, không có tệp đính kèm.\"\n        }\n    }]\n\nfor i in range(len(items)):\n\n    currentItem = items[i]\n    json_data = currentItem[\"json\"]\n\n    aiResponse = str(\n        json_data.get(\"output\", {}).get(\"text\")\n        or json_data.get(\"output\")\n        or json_data.get(\"text\")\n        or json_data.get(\"response\")\n        or \"\"\n    )\n\n    fileName = json_data[\"output\"][\"file_name\"]\n    subject = json_data[\"output\"][\"subject\"]\n    sender = json_data[\"output\"][\"sender\"]\n    emailBody = json_data[\"output\"][\"email_body\"]\n\n    fileSummary = \"\"\n\n    if aiResponse.strip():\n        fileSummary = f\"{aiResponse.strip()}\"\n    else:\n        fileSummary = \"(Không có nội dung tóm tắt từ AI)\"\n\n    outputItems.append({\n        \"json\": {\n            \"subject\": subject,\n            \"sender\": sender,\n            \"email_body\": emailBody,\n            \"fileName\": fileName,\n            \"text\": fileSummary\n        }\n    })\n\nreturn outputItems"
      },
